PORT=8080
# Optional: set this to use MongoDB instead of local JSON file storage.
# MONGODB_URI=mongodb://127.0.0.1:27017/employee-management-system

# Optional: set these to use Google Sheets instead of MongoDB/local JSON.
# The spreadsheet must be shared with the service account email.
# GOOGLE_SHEETS_SPREADSHEET_ID=1mUUcwb7vVIYIG7zu7mnyxUSiNccG539MXKx62mKZHDk
# GOOGLE_SHEETS_TAB_NAME=Sheet1
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Or use a downloaded service-account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=C:\absolute\path\to\service-account.json
